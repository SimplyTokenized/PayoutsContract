# =============================================================================
# PayoutsContract — Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in the values. NEVER commit your real `.env`.
#   cp .env.example .env
#
# WARNING: Private keys grant full control of the associated funds. Use a
# dedicated deployer account, prefer hardware wallets / keystores for mainnet,
# and rotate any key that has ever been pasted in plaintext.
# =============================================================================

# --- Deployment parameters (required by script/DeployPayouts.s.sol) ----------
# Address of the ERC20 token whose historical balances determine allocations.
BASE_TOKEN=0x0000000000000000000000000000000000000000
# Address that receives all admin roles and proxy-admin ownership on deploy.
ADMIN=0x0000000000000000000000000000000000000000

# --- Deployer identity -------------------------------------------------------
# Private key of the account that broadcasts deployment transactions.
DEPLOYER_KEY=
# Public address matching DEPLOYER_KEY (used as --sender).
DEPLOYER=0x0000000000000000000000000000000000000000

# --- RPC endpoints -----------------------------------------------------------
RPC_URL=
TESTNET_RPC=
ETH_SEPOLIA_RPC=
AVALANCHE_FUJI_RPC=
MAINNET_RPC=

# --- Contract verification ---------------------------------------------------
ETHERSCAN_API_KEY=
AVALANCHE_FUJI_VERIFIER_URL=

# --- Local development (Anvil) -----------------------------------------------
# The `deploy:local` script uses Anvil's well-known first account. That key is a
# publicly known test key — never send real funds to it.
PRIVATE_KEY=
